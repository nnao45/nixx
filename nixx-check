#!/usr/bin/env python3
"""nixx-check — lint nixx blocks in any supported language, mapped to .nix source.

Usage: nixx-check <file.nix> [attr]   (default attr: meta)
Picks the linter from each block's `lang`: bash->shellcheck, python->ruff.
Diagnostics are remapped to the ORIGINAL .nix file:line:col.
"""
import json, subprocess, sys, tempfile, os

def eval_meta(nix_file, attr="meta"):
    out = subprocess.run(
        ["nix-instantiate","--eval","--strict","--json","-E",f"(import {nix_file}).{attr}"],
        capture_output=True, text=True)
    if out.returncode != 0:
        sys.stderr.write(out.stderr); sys.exit(2)
    return json.loads(out.stdout)

# Each linter returns a list of {line, col, level, code, msg} in BODY coords.
def lint_bash(text):
    sc = subprocess.run(["shellcheck","--format=json","--shell=bash","-"],
                        input=text, capture_output=True, text=True)
    return [{"line":d["line"],"col":d["column"],"level":d["level"],
             "code":f'SC{d["code"]}',"msg":d["message"]}
            for d in json.loads(sc.stdout or "[]")]

def lint_python(text):
    with tempfile.NamedTemporaryFile("w",suffix=".py",delete=False) as f:
        f.write(text); path=f.name
    try:
        r = subprocess.run(["ruff","check","--output-format=json","--no-cache",path],
                           capture_output=True, text=True)
        out = []
        for d in json.loads(r.stdout or "[]"):
            loc = d.get("location") or {}
            out.append({"line":loc.get("row",1),"col":loc.get("column",1),
                        "level":d.get("severity","error"),
                        "code":d.get("code") or "?","msg":d["message"]})
        return out
    finally:
        os.unlink(path)

LINTERS = {"bash":lint_bash, "python":lint_python}

def main():
    if len(sys.argv) < 2: sys.exit(__doc__)
    f = sys.argv[1]
    if not f.startswith(("/","./","../")): f = "./" + f
    attr = sys.argv[2] if len(sys.argv) > 2 else "meta"
    issues = 0
    for t in eval_meta(f, attr):
        lang = t.get("lang","bash")
        linter = LINTERS.get(lang)
        if linter is None:
            print(f'nixx-check: no linter for lang={lang} (block {t["name"]})',
                  file=sys.stderr); continue
        for d in linter(t["text"]):
            base = t.get("line"); indent = t.get("indent",0)
            src_file = t.get("file") or f
            if base is not None:
                line = base + d["line"] - 1
                col = d["col"] + indent
                loc = f"{src_file}:{line}:{col}"
            else:
                loc = f'{src_file} [{t["name"]}] body {d["line"]}:{d["col"]}'
            print(f'{loc}: {d["level"]}: {d["code"]} {d["msg"]}  [{lang}: {t["name"]}]')
            issues += 1
    print(f"nixx-check: {'all clean ✓' if issues==0 else str(issues)+' issue(s)'}",
          file=sys.stderr)
    sys.exit(1 if issues else 0)

if __name__ == "__main__":
    main()
