---
import Base from "../layouts/Base.astro";
import { base } from "../lib/base";

const items = [
  {
    href: `${base}llms.txt`,
    name: "/llms.txt",
    desc: "Quickstart for LLMs — what nixx is, how to install, how to use it (mkApps / mkTasks / vars), and the gotchas. Plus links to the full reference.",
  },
  {
    href: `${base}llms-full.txt`,
    name: "/llms-full.txt",
    desc: "The full docs — README + API reference concatenated as plain markdown, ready to drop into an LLM context.",
  },
];
---

<Base
  title="nixx — for LLMs"
  description="Plain-text docs for language models: the llms.txt index and the full llms-full.txt dump."
>
  <div class="mx-auto w-full max-w-3xl px-4 py-16 sm:px-6">
    <p class="font-mono text-sm text-amber-500">// for language models</p>
    <h1 class="mt-3 font-mono text-3xl font-semibold tracking-tight text-balance">nixx, condensed for LLMs</h1>
    <p class="mt-4 max-w-[60ch] text-lg leading-relaxed text-neutral-600 text-pretty dark:text-neutral-400">
      Two plain-text files describe nixx for agents and assistants — no navigation, no chrome, just the docs.
    </p>

    <ul role="list" class="mt-8 flex flex-col gap-3">
      {items.map((it) => (
        <li class="rounded-lg border border-neutral-200 p-4 dark:border-neutral-800">
          <a href={it.href} class="font-mono text-amber-600 transition-colors hover:underline dark:text-amber-400">{it.name}</a>
          <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">{it.desc}</p>
        </li>
      ))}
    </ul>
  </div>
</Base>
